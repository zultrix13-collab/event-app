# ============================================================
# SaaS Base — Environment Variables
# cp .env.example .env.local  гэж хуулаад утгуудыг бөглөнө үү
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── QPay V2 (Billing) ────────────────────────────────────────
# https://merchant.qpay.mn
# Webhook auth нь invoice тус бүрийн random token ашигладаг (global secret биш).
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_INVOICE_CODE=

# ── Admin / Internal Ops ─────────────────────────────────────
# Comma-separated emails: bootstrap (empty system_admins), legacy /internal/ops, env operator mutations.
# /admin uses system_admins; see docs/admin-auth-v1.md
INTERNAL_OPS_EMAILS=

# ── Event App Auth ───────────────────────────────────────────
DIGITAL_ID_SECRET=your-secret-key-here
NEXT_PUBLIC_EVENT_ID=event-2026

# ── QPay Services (Sprint 3) ─────────────────────────────────
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=

# ── Integration Slot ─────────────────────────────────────────
# Өөрийн integration provider-ийн credentials энд нэм.
# src/modules/integrations/<name>/ дотор тохируулна.
INTEGRATION_PROVIDER_ID=
INTEGRATION_PROVIDER_SECRET=

# ── AI (Optional) ────────────────────────────────────────────
# AI feature ашиглах бол uncomment хийж утгийг бөглөнө үү.
OPENAI_API_KEY=sk-...          # Required for AI chatbot (Sprint 4-A RAG)
# AI_MODEL=gpt-4o-mini
